name: 🔄 Revert History_HVE.csv from LFS

on:
  workflow_dispatch:

jobs:
  revert-lfs:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          lfs: true
          fetch-depth: 0

      - name: Install Git LFS
        run: git lfs install

      - name: Remove LFS tracking for the file
        run: |
          git lfs untrack "HVE/History_HVE.csv"
          
          # Remove the file from LFS and restore as normal file
          git rm --cached "HVE/History_HVE.csv"
          git add "HVE/History_HVE.csv"
          
          # Update .gitattributes
          git add .gitattributes

      - name: Commit and Push Revert
        run: |
          git config user.name "GitHub Actions"
          git config user.email "actions@github.com"
          git commit -m "Revert: Remove History_HVE.csv from Git LFS"
          git push
